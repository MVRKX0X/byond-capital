# =====================================================================
# Byond Capital — environment variables
#
# This site is split into two deployments:
#   1) Static site  → Cloudflare Pages    (uses NEXT_PUBLIC_* vars below)
#   2) API Worker   → Cloudflare Workers  (uses server-side vars at bottom)
#
# For local dev: copy this file to .env.local in the repo root.
# For Pages:     paste NEXT_PUBLIC_* vars into Pages → Settings → Env Vars.
# For Worker:    use `wrangler secret put NAME` for secret vars
#                (set NEXT_PUBLIC_* are NOT needed in the worker).
# =====================================================================

# ===== CLIENT (Cloudflare Pages env vars) =====

# URL where the API Worker is reachable.
# After custom DNS:    https://api.byondcapital.co
# Before custom DNS:   https://byond-capital-api.<your-subdomain>.workers.dev
NEXT_PUBLIC_API_BASE_URL=

# ----- Whop checkout URLs (one per Club tier) -----
NEXT_PUBLIC_WHOP_FREE_URL=
NEXT_PUBLIC_WHOP_MONTHLY_URL=
NEXT_PUBLIC_WHOP_QUARTERLY_URL=
NEXT_PUBLIC_WHOP_ANNUAL_URL=
NEXT_PUBLIC_WHOP_VIP_URL=

# ----- Booking (Calendly or Google Calendar embed URL) -----
# Must be an embed URL, e.g. https://calendly.com/byondcapital/intro?embed_type=Inline
NEXT_PUBLIC_BOOKING_EMBED_URL=

# ----- Analytics -----
NEXT_PUBLIC_META_PIXEL_ID=


# ===== WORKER (set via `wrangler secret put NAME`) =====

# ManyChat External Request webhook — receives playbook opt-ins:
# { email, first_name, source, submitted_at }
MANYCHAT_WEBHOOK_URL=

# Contact form transport — pick ONE path:

# Path A: Resend (preferred — proper transactional email)
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@byondcapital.co
CONTACT_FROM_EMAIL=Byond Capital <hello@byondcapital.co>

# Path B: Generic webhook (Zapier / n8n / ManyChat External Request)
CONTACT_WEBHOOK_URL=
